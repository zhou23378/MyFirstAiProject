# Salon Manager — Environment Variables
# Copy this file to .env and fill in your production values
# cp .env.example .env

# MySQL
DB_PASSWORD=salon123

# JWT (production: use a random 256-bit key, e.g. openssl rand -base64 32)
JWT_SECRET=change-me-in-production-please-change-me-at-least-32-bytes
JWT_EXPIRATION=86400000

# Ports (change if you have conflicts)
MYSQL_PORT=3306
BACKEND_PORT=8080
FRONTEND_PORT=80
AI_PORT=8000

# AI service
CORS_ORIGINS=http://localhost:80,http://localhost:3000

# Optional external integrations. Leave empty for Docker smoke/demo mode.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_APP_ID=
WECHAT_PAY_NOTIFY_URL=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
